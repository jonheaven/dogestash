{
  "name": "@jonheaven/dogestash",
  "version": "1.0.0",
  "private": false,
  "description": "Dogecoin wallet toolkit with browser wallet core, adapters, and React integrations.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./lib/browser-wallet": {
      "types": "./dist/lib/browser-wallet.d.ts",
      "import": "./dist/lib/browser-wallet.js"
    },
    "./adapters/BrowserWalletSigner": {
      "types": "./dist/adapters/BrowserWalletSigner.d.ts",
      "import": "./dist/adapters/BrowserWalletSigner.js"
    },
    "./providers/DogestashProvider": {
      "types": "./dist/providers/DogestashProvider.d.ts",
      "import": "./dist/providers/DogestashProvider.js"
    },
    "./components/ConnectWalletButton": {
      "types": "./dist/components/ConnectWalletButton.d.ts",
      "import": "./dist/components/ConnectWalletButton.js"
    },
    "./contexts/UnifiedWalletContext": {
      "types": "./dist/contexts/UnifiedWalletContext.d.ts",
      "import": "./dist/contexts/UnifiedWalletContext.js"
    },
    "./wallet/getConnectedWalletAddress": {
      "types": "./dist/wallet/getConnectedWalletAddress.d.ts",
      "import": "./dist/wallet/getConnectedWalletAddress.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:js": "vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run build:js && npm run build:types",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit",
    "check": "npm run test && npm run build",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run check && npm run pack:check"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.0.18",
    "@ledgerhq/hw-app-btc": "^10.18.0",
    "@ledgerhq/hw-transport-webusb": "^6.30.0",
    "@mydogeofficial/dogecoin-js": "^0.1.2-dev.0",
    "@noble/secp256k1": "^3.0.0",
    "@scure/bip32": "^1.3.0",
    "@scure/bip39": "^2.0.1",
    "axios": "^1.6.5",
    "chart.js": "^4.4.3",
    "cors": "^2.8.5",
    "doge-sdk": "^0.5.0-beta.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "lucide-react": "^0.577.0",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": ">=18",
    "react-chartjs-2": "^5.2.0",
    "react-dom": ">=18",
    "react-dropzone": "^15.0.0",
    "react-hot-toast": "^2.6.0",
    "socket.io-client": "^4.7.4",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@rollup/plugin-inject": "^5.0.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bip39": "^3.0.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^19.2.3",
    "@types/w3c-web-usb": "^1.0.13",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "assert": "^2.1.0",
    "autoprefixer": "^10.4.17",
    "buffer": "^6.0.3",
    "events": "^3.3.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.33",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "typescript": "^5.6.2",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "keywords": [
    "dogecoin",
    "wallet",
    "react",
    "web3",
    "marketplace"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
