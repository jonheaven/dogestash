{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["vite/client"],
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "noCheck": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/index.ts",
    "src/lib/browser-wallet.ts",
    "src/adapters/BrowserWalletSigner.ts",
    "src/providers/DogestashProvider.tsx",
    "src/components/ConnectWalletButton.tsx",
    "src/components/WalletSelectionModal.tsx",
    "src/contexts/BrowserWalletContext.tsx",
    "src/contexts/UnifiedWalletContext.tsx",
    "src/wallet/getConnectedWalletAddress.ts"
  ],
  "exclude": ["src/tests/**", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
